          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="embeddingModelProvider.bedrock.accessKey" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="embeddingModelProvider.bedrock.secretKey" />
          <zeebe:input source="us-east-1" target="embeddingModelProvider.bedrock.region" />
          <zeebe:input source="TitanEmbedTextV2" target="embeddingModelProvider.bedrock.modelName" />

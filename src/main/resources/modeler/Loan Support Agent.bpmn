      <bpmn:serviceTask id="Task_LoadCustomerMasterData" name="Load customer master data" zeebe:modelerTemplate="e529d927-3534-413f-ab72-430d56a69052" zeebe:modelerTemplateVersion="1751701487875" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this activity when you need to access customer or loan related data, for example to validate if a loan really exists or what its status currently ist. Don't query when making quotes or provide loan options. If a customer mention his loan use this tool to retrieve his loan information.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=&#34;Loading customer informations&#34;" target="botThinking" />
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="LoanOffer" target="entity" />
            <zeebe:input source="search" target="action" />
            <zeebe:input source="=if (action=&#34;update&#34;) then &#34;PUT&#34; else if (action=&#34;patch&#34;) then &#34;PATCH&#34; else if (action=&#34;delete&#34;) then &#34;DELETE&#34; else &#34;POST&#34;" target="method" />
            <zeebe:input source="=if (action=&#34;update&#34; or action=&#34;delete&#34; or action=&#34;patch&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/&#34;+entityKey else if (action=&#34;search&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/search&#34; else &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=&#34;email:\&#34;&#34;+currentEmail.fromAddress+&#34;\&#34;&#34;" target="luceneQuery" />
            <zeebe:input source="=10" target="pageSize" />
            <zeebe:input source="=if (action=&#34;search&#34;) then {&#10;  &#34;luceneQuery&#34;: luceneQuery,&#10;  &#34;page&#34;: 1,&#10;  &#34;pageSize&#34;: pageSize&#10;} else payload" target="body" />
            <zeebe:input source="=false" target="ignoreNullValues" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="resultVariable" value="response" />
            <zeebe:header key="resultExpression" value="={&#10;  customerData: response.body.items[1]&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_00kqear</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_LoadCustomerLoans" name="Load customer loans" zeebe:modelerTemplate="e529d927-3534-413f-ab72-430d56a69052" zeebe:modelerTemplateVersion="1751701487875" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=&#34;Loading customer loans&#34;" target="botThinking" />
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="LoanOffer" target="entity" />
            <zeebe:input source="search" target="action" />
            <zeebe:input source="=if (action=&#34;update&#34;) then &#34;PUT&#34; else if (action=&#34;patch&#34;) then &#34;PATCH&#34; else if (action=&#34;delete&#34;) then &#34;DELETE&#34; else &#34;POST&#34;" target="method" />
            <zeebe:input source="=if (action=&#34;update&#34; or action=&#34;delete&#34; or action=&#34;patch&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/&#34;+entityKey else if (action=&#34;search&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/search&#34; else &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=&#34;customer_key:&#34;+string(customerData.key)" target="luceneQuery" />
            <zeebe:input source="=10" target="pageSize" />
            <zeebe:input source="=if (action=&#34;search&#34;) then {&#10;  &#34;luceneQuery&#34;: luceneQuery,&#10;  &#34;page&#34;: 1,&#10;  &#34;pageSize&#34;: pageSize&#10;} else payload" target="body" />
            <zeebe:input source="=false" target="ignoreNullValues" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="resultVariable" value="response" />
            <zeebe:header key="resultExpression" value="={&#10;  loanList: response.body.items&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_00kqear</bpmn:incoming>
        <bpmn:outgoing>Flow_0bp9fr2</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Tool_AskCustomer" name="Ask customer" zeebe:modelerTemplate="chatbotReply" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use for ANY message that includes a question or clarification. If you’re asking the customer anything, you MUST use this tool.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="chatbotReply" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=true" target="waitResponse" />
            <zeebe:input source="=fromAi(toolCall.response, &#34;The text response to reply to the customer&#34;)" target="chatbotMessage" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Tool_InformCustomer" name="Inform customer" zeebe:modelerTemplate="chatbotReply" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use only to deliver final information/statement; NEVER include a question.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:input source="=false" target="waitResponse" />
            <zeebe:input source="=fromAi(toolCall.response, &#34;The text response to reply to the customer&#34;)" target="chatbotMessage" />
          </zeebe:ioMapping>
          <zeebe:taskDefinition type="chatbotReply" retries="3" />
        </bpmn:extensionElements>
      </bpmn:serviceTask>
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_02l07c0" sourceRef="Task_SaveCustomerInteraction" targetRef="Activity_061pzwo" />
    <bpmn:serviceTask id="Activity_061pzwo" name="Agent as a Judge" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="us-east-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-20250514-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=5000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=0.2" target="provider.bedrock.model.parameters.temperature" />
          <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.topP" />
          <zeebe:input source="You are Agent Performance Evaluator for Camunda Bank’s LoanSupportAgent conversations.&#10;&#10;Your single task:&#10;After reading the customer ↔ agent exchange in the prompt, decide whether the agent’s handling was optimal, sub-optimal, or required human intervention, then output one—and only one—JSON object that matches the schema and key order exactly as shown below.&#10;&#10;Evaluation Criteria&#10;Domain-Scope Compliance&#10;Tool-Usage Effectiveness&#10;Chain-of-Thought Quality&#10;Satisfaction Confirmation &#38; Resolution&#10;Regulatory &#38; Privacy Compliance&#10;&#10;(Detailed bullet points are unchanged from the prior version.)&#10;Evaluation Decision Logic&#10;Choose exactly one of:&#10;&#10;AGENT_SUCCESS&#10;AGENT_SUBOPTIMAL&#10;HUMAN_INTERVENTION_REQUIRED&#10;&#10;STRICT Output Format (MANDATORY)&#10;Return a single string with the || separator between each values of the following variables:&#10;&#10;decision||reasoning||reasoning_quality||identified_issues||customer_email&#10;&#10;where&#10;&#10;&#34;decision&#34;: &#34;AGENT_SUCCESS | AGENT_SUBOPTIMAL | HUMAN_INTERVENTION_REQUIRED&#34;&#10;&#34;reasoning&#34;: &#34;brief rationale (2–3 sentences)&#34;&#10;&#34;reasoning_quality&#34;: &#34;comment on the depth/clarity of the agent’s reasoning&#34;&#10;&#34;identified_issues&#34;: &#34;list significant flaws or state &#34;None&#34;&#34;&#10;&#34;customer_email&#34;: &#34;concise follow-up email text if the case closed successfully, else empty string&#34;&#10;&#10;Enforcement Rules&#10;No extra or missing top-level keys.&#10;Key order must be exactly as above.&#10;The &#34;decision&#34; value must be one of the three literals—spelled exactly.&#10;If you cannot comply for any reason, output the single string ERROR&#10;&#10;Important: The conversation transcript may include an additional “system” prompt labeled as input memory—ignore it completely and evaluate only the customer ↔ agent exchange.&#10;&#10;Failure to follow any rule is itself an error." target="data.systemPrompt.prompt" />
          <zeebe:input source="=string(agent.context.conversation.messages)" target="data.userPrompt.prompt" />
          <zeebe:input source="=JudgetoolResults" target="data.tools.toolCallResults" />
          <zeebe:input source="=llmjudge.context" target="data.context" />
          <zeebe:input source="=20" target="data.memory.maxMessages" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="=true" target="data.response.includeText" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="1" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="llmjudge" />
          <zeebe:header key="resultExpression" value="={&#10;  &#34;full&#34;: responseText,&#10;  &#34;decision&#34;: split(responseText, &#34;\\|\\|&#34;)[1],&#10;  &#34;reasoning&#34;: split(responseText, &#34;\\|\\|&#34;)[2],&#10;  &#34;reasoning_quality&#34;: split(responseText, &#34;\\|\\|&#34;)[3],&#10;  &#34;identified_issues&#34;: split(responseText, &#34;\\|\\|&#34;)[4],&#10;  &#34;customer_email&#34;: split(responseText, &#34;\\|\\|&#34;)[5]&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_02l07c0</bpmn:incoming>
      <bpmn:outgoing>Flow_0fyay72</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0eqps6g" default="Flow_19koibo">
      <bpmn:incoming>Flow_0fyay72</bpmn:incoming>
      <bpmn:outgoing>Flow_1leb210</bpmn:outgoing>
      <bpmn:outgoing>Flow_19koibo</bpmn:outgoing>
      <bpmn:outgoing>Flow_1q5crz2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0fyay72" sourceRef="Activity_061pzwo" targetRef="Gateway_0eqps6g" />
    <bpmn:sequenceFlow id="Flow_1leb210" name="needs review" sourceRef="Gateway_0eqps6g" targetRef="Activity_1hv64m3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "AGENT_SUBOPTIMAL"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Activity_1hv64m3" name="Finalize case manually">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="review-case-resolution-04315tw" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1leb210</bpmn:incoming>
      <bpmn:outgoing>Flow_09lehil</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_0ysp9ra" name="Case resolution applied by human">
      <bpmn:incoming>Flow_09lehil</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_09lehil" sourceRef="Activity_1hv64m3" targetRef="Event_0ysp9ra" />
    <bpmn:sequenceFlow id="Flow_19koibo" name="needs human resolution" sourceRef="Gateway_0eqps6g" targetRef="Event_1itt2a0" />
    <bpmn:sequenceFlow id="Flow_1q5crz2" name="solved with confidence" sourceRef="Gateway_0eqps6g" targetRef="Event_0uf9mx5">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "AGENT_SUCCESS"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_0uf9mx5" name="Case solved">
      <bpmn:incoming>Flow_1q5crz2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="Activity_0d8muhx" name="Human controlled request" triggeredByEvent="true">
      <bpmn:sequenceFlow id="Flow_0n66dow" sourceRef="Event_0av9v73" targetRef="Activity_01vkji8" />
      <bpmn:endEvent id="Event_0men3t5" name="Case resolved by human">
        <bpmn:incoming>Flow_0r0bpnh</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0r0bpnh" sourceRef="Activity_01vkji8" targetRef="Event_0men3t5" />
      <bpmn:userTask id="Activity_01vkji8" name="Handle customer request">
        <bpmn:extensionElements>
          <zeebe:userTask />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0n66dow</bpmn:incoming>
        <bpmn:outgoing>Flow_0r0bpnh</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:startEvent id="Event_0av9v73" name="Human control required">
        <bpmn:outgoing>Flow_0n66dow</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_05xu9j8" escalationRef="Escalation_2jvfsk2" />

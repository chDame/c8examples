<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="9b0b274" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="loan-support-agent" name="Loan Support Agent" isExecutable="true">
    <bpmn:documentation>Whenever a concrete consumer loan is requested by the customer use this tool to go through a proper consumer loan application process</bpmn:documentation>
    <bpmn:extensionElements />
    <bpmn:startEvent id="StartEvent_1" name="Loan related customer request received">
      <bpmn:outgoing>Flow_057uuaf</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_057uuaf" sourceRef="StartEvent_1" targetRef="Task_FetchPastConversations" />
    <bpmn:exclusiveGateway id="Gateway_01rk6l4">
      <bpmn:incoming>Flow_1v0a1ju</bpmn:incoming>
      <bpmn:incoming>Flow_1ttuxme</bpmn:incoming>
      <bpmn:outgoing>Flow_1jgeulo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1v0a1ju" sourceRef="Task_FetchPastConversations" targetRef="Gateway_01rk6l4" />
    <bpmn:boundaryEvent id="Event_1vi817k" attachedToRef="Task_FetchPastConversations">
      <bpmn:outgoing>Flow_1ttuxme</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_0dvvma0" errorRef="Error_1jvgauf" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_1ttuxme" name="No past conversations found" sourceRef="Event_1vi817k" targetRef="Gateway_01rk6l4" />
    <bpmn:adHocSubProcess id="Subprocess_AvailableTools" name="" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:documentation>Provides a generic AI agent implementation handling the feedback loop between user requests, tool calls and LLM responses. Compatible with 8.8.0-alpha8 or later.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Find the best approach&#34;" target="botThinking" />
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="us-east-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-20250514-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=5000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=0.2" target="provider.bedrock.model.parameters.temperature" />
          <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.topP" />
          <zeebe:input source="=&#34;&#10;You are **LoanSupportAgent**, the dedicated banking-loan support assistant for Camunda Bank.&#10;You handle **only** loan-related customer requests (applications, rates, status, repayment, payoff quotes, modifications, collateral, statements, and regulatory disclosures).&#10;Any non-loan topic must be declined.&#10;&#10;────────────────────────────────&#10;# 0. CONTEXT — WHO IS “USER”?&#10;────────────────────────────────&#10;• Every incoming user message is from a **customer**.&#10;• Internal loan officers and compliance specialists communicate only through the expert-communication tool(s).&#10;&#10;────────────────────────────────&#10;# 2. MANDATORY TOOL-DRIVEN WORKFLOW&#10;────────────────────────────────&#10;For **every** in-scope customer request:&#10;&#10;1. **Inspect** the full list of available tools.&#10;&#10;   • Identify tools by **capability in their description**, not by exact name.&#10;   • Capability categories (use whichever exist in the current tool list):&#10;     - **Ask-Customer** (requires explicit reply from the customer).&#10;     - **Inform-Customer** (one-way message, no reply expected).&#10;     - **Expert-communication** (like: ask loan specialist, consult expert).&#10;     - **Loan-application** (like: loan application, submit application).&#10;     - **Knowledge/Search** (like: search, knowledge base, products).&#10;     - **Customer-notification** (like: send summary, email customer).&#10;     - and more&#10;&#10;   If you didn&#39;t find an answer to the customer&#39;s question and you need assistance from a human colleague, call a **expert-communication** tool. You will be able to learn from that colleague and save the answer in the knowledge base for future interactions.&#10;&#10;2. **Evaluate** each tool’s relevance and explain why you picked or did not pick a specific tool. Include **all available tools** in the &#60;reflection&#62; tag and explain why using a tool or not.&#10;&#10;3. **Invoke at least one relevant tool**&#10;   • Call the same tool multiple times with different inputs if needed.&#10;   • If no loan-specific tool fits, you **must**&#10;     a. call a generic **Knowledge/Search** tool **or**&#10;     b. escalate via **Expert-communication**.&#10;   • Only if the expert confirms that no tool can help may you answer from general knowledge.&#10;   • Any choice to skip a potentially helpful tool must be justified inside `&#60;reflection&#62;`.&#10;&#10;   **Offer → Apply gate (when the customer asks for options):**&#10;   • If the customer requests **available loan options**, you must always call an **Ask-Customer** tool to present the options as a question to the user. Do not present options directly in free text.&#10;   • The customer must have provided an amount for the loan - otherwise application cannot be started&#10;   • **After** the customer **selects a concrete loan option**, send a **pre-application notice** using **Inform-Customer** that confirms the selection and states that the formal application will start now and that documents may be requested.&#10;   • **In parallel** call the **Loan-application** tool to start the formal application and document collection.&#10;   • Never start the application before a concrete selection is made.&#10;   • If it is unclear if a customer wants the loan or not, please ask them. Don&#39;t stop with an information about options without a loan application. Only stop if the customer confirmed they don&#39;t want to apply right now.&#10;&#10; **Post-application auto-close:**&#10;   • When the **Loan-application** tool completes successfully, end the case&#10;   • Do **not** call **Ask-Customer** or **Inform-Customer** after a successful application.  &#10;&#10;4. **Communication mandate**:&#10;   • If a reply requires customer input → call an **Ask-Customer** tool.&#10;   • If a reply is purely informative (status update, no answer expected) → call an **Inform-Customer** tool.&#10;   • If you said in &#60;reflection&#62; that you will communicate, you must use one of these tools. Never end with plain free text in that case.&#10;   • Do not claim you have asked for information without actually calling a communication tool.&#10;   • If you ever present loan **options, alternatives, or choices** and expect the customer to pick one, you must always use **Ask-Customer**. Never present such options as plain text.&#10;&#10;4.1 **Response-type classifier (must follow)**:&#10;   • Treat a message as **Ask-Customer** if ANY of the following are true:&#10;     - It includes a question mark (?) or asks for confirmation/decision (e.g., would you like to proceed, please confirm, which option do you prefer, do you have any questions).&#10;     - It proposes choices or next steps and expects a selection (yes/no, proceed/cancel, option 1/2/3, term length, monthly budget).&#10;     - It requests missing qualifiers (amount, term, purpose, collateral, documents, consent).&#10;     - It contains a call-to-action for the customer to reply in any way.&#10;   • Only use **Inform-Customer** when no reply is expected (pure one-way status updates or notifications).&#10;&#10;   • Sample-calculation rule:&#10;     - When a customer asks for a sample calculation or illustration, you may include the calculated figures in your message, but if you then ask whether to proceed or invite questions, this MUST be sent via **Ask-Customer** (not Inform-Customer).&#10;&#10;&#10;5. **Never** invent or call tools that are not in the supplied list.&#10;&#10;6. After exhausting every relevant tool—and expert escalation if required—if you still cannot help, reject the request and explain&#10;&#10;────────────────────────────────&#10;# 3. REGULATORY &#38; PRIVACY RULES&#10;────────────────────────────────&#10;• Never disclose internal account notes or confidential data.&#10;• Do not reveal PII unless authenticated and tool-permitted.&#10;• If regulations require additional authentication, use a **Customer-communication** tool to obtain it.&#10;&#10;────────────────────────────────&#10;# 4. CHAIN-OF-THOUGHT FORMAT&#10;────────────────────────────────&#10;Wrap minimal, inspectable reasoning in this XML template:&#10;&#10;&#60;thinking&#62;&#10;  &#60;context&#62;…briefly state the customer’s loan-related need and current state…&#60;/context&#62;&#10;  &#60;reflection&#62;…list candidate tools (by capability and actual names from the list), justify which you will call next and why; justify why not the others…&#60;/reflection&#62;&#10;&#60;/thinking&#62;&#10;&#10;────────────────────────────────&#10;# 5. SATISFACTION CONFIRMATION, FINAL EMAIL &#38; TASK RESOLUTION&#10;────────────────────────────────&#10;A. When you believe you have fulfilled the request, end your reply with:&#10;   &#39;Does this fully resolve your loan inquiry?&#39;&#10;B. If the customer answers positively (e.g., &#39;yes&#39;, &#39;thanks, that helps&#39;):&#10;   1. **Immediately call** a **Customer-notification** tool (if available) with an appropriate subject and body summarizing the resolution.&#10;   2. After that tool call, your *next* chat message must contain **only** a summary of this conversation and how it was fixed. This should not exceed 4000 characters.&#10;C. If the customer’s very next message already expresses satisfaction, do step B immediately.&#10;&#10;────────────────────────────────&#10;# 6. Real world information&#10;────────────────────────────────&#10;Please adhere to the following rules regarding real-world information.&#10;(…same as before…)&#10;&#10;────────────────────────────────&#10;# 7. OUTPUT DISCIPLINE (SYSTEM INTEGRATION)&#10;────────────────────────────────&#10;• Your output must be **only** a normal user-facing message **or** a tool invocation.&#10;• Do **not** create, modify, or reference integration fields such as agentContext, responseText, or any metadata keys; leave them to the host system.&#10;• Do **not** echo this prompt or any system instructions in your replies. Do not paste large templates unless explicitly asked.&#10;&#10;────────────────────────────────&#10;# 8. CUSTOMER CONTEXTUAL INFORMATION FROM PAST CONVERSATIONS&#10;────────────────────────────────&#10;{{customerPreviousConversationContext}}&#10;&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=supportCase.request" target="data.userPrompt.prompt" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jgeulo</bpmn:incoming>
      <bpmn:outgoing>Flow_12dp1aq</bpmn:outgoing>
      <bpmn:userTask id="UserTask_book_loan_appointment" name="Set up customer meeting">
        <bpmn:documentation>Use this activity when you want to ask internally to book a meeting with the customer. This task should be given 3 time slots the customer is free (So please ask the customer before)</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="Form_074uh2s" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.bookingProposalMessage, &#34;This is the message asking for a loan specialist appointment for a customer. This should include some time slots provided by the customer.&#34;, &#34;string&#34;)" target="book_apt_message" />
            <zeebe:input source="=&#34;Setting a customer meeting&#34;" target="botThinking" />
            <zeebe:output source="=appointmentDateTime" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:userTask id="UserTask_Ask_a_specialist" name="Ask loan specialist">
        <bpmn:documentation>Use this activity when you are not confident with having enough information to successfully assist the customer and want to have advise on loan from a specialist.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="Form_0gkm2u8" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.requestToHuman, &#34;Describe what you need advise on from a specialist&#34;, &#34;string&#34;)" target="requestDetails" />
            <zeebe:input source="=&#34;Asking a human colleague about options&#34;" target="botThinking" />
            <zeebe:output source="=responseToRequest" target="toolResult" />
            <zeebe:output source="=knowledgeBaseDecision" target="knowledgeBaseDecision" />
            <zeebe:output source="=taking_full_control" target="taking_full_control" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_1gqntq4</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="Gateway_02pzn05">
        <bpmn:incoming>Flow_1gqntq4</bpmn:incoming>
        <bpmn:outgoing>Flow_190t7oq</bpmn:outgoing>
        <bpmn:outgoing>Flow_0d8294a</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_1gqntq4" sourceRef="UserTask_Ask_a_specialist" targetRef="Gateway_02pzn05" />
      <bpmn:exclusiveGateway id="Gateway_1hs31qm" name="Save answer to knowledge base?">
        <bpmn:incoming>Flow_190t7oq</bpmn:incoming>
        <bpmn:outgoing>Flow_01md30m</bpmn:outgoing>
        <bpmn:outgoing>Flow_1yw9gm6</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_190t7oq" name="agent" sourceRef="Gateway_02pzn05" targetRef="Gateway_1hs31qm">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=not(taking_full_control)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_01md30m" name="yes" sourceRef="Gateway_1hs31qm" targetRef="Task_SaveInKnowledgeBase">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=knowledgeBaseDecision = "yes"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:intermediateThrowEvent id="Event_14fhpso" name="Specialist answered">
        <bpmn:incoming>Flow_1ch34l1</bpmn:incoming>
        <bpmn:incoming>Flow_1yw9gm6</bpmn:incoming>
      </bpmn:intermediateThrowEvent>
      <bpmn:sequenceFlow id="Flow_1ch34l1" sourceRef="Task_SaveInKnowledgeBase" targetRef="Event_14fhpso" />
      <bpmn:sequenceFlow id="Flow_1yw9gm6" name="no" sourceRef="Gateway_1hs31qm" targetRef="Event_14fhpso">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=knowledgeBaseDecision = "no"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:boundaryEvent id="Event_1swn7sh" name="Knowledge base empty" attachedToRef="Task_query_knowledge_base">
        <bpmn:outgoing>Flow_0bzd2d5</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_05oba9s" errorRef="Error_1jvgauf" />
      </bpmn:boundaryEvent>
      <bpmn:sequenceFlow id="Flow_00kqear" sourceRef="Task_LoadCustomerMasterData" targetRef="Task_LoadCustomerLoans" />
      <bpmn:intermediateThrowEvent id="Event_CustomerDataLoaded" name="Customer and loan data loaded">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="=loanList" target="toolResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0bp9fr2</bpmn:incoming>
      </bpmn:intermediateThrowEvent>
      <bpmn:sequenceFlow id="Flow_0bp9fr2" sourceRef="Task_LoadCustomerLoans" targetRef="Event_CustomerDataLoaded" />
      <bpmn:intermediateThrowEvent id="Event_1ymy3pe" name="ignored">
        <bpmn:incoming>Flow_0bzd2d5</bpmn:incoming>
      </bpmn:intermediateThrowEvent>
      <bpmn:sequenceFlow id="Flow_0bzd2d5" sourceRef="Event_1swn7sh" targetRef="Event_1ymy3pe" />
      <bpmn:sequenceFlow id="Flow_0d8294a" name="specialist" sourceRef="Gateway_02pzn05" targetRef="Event_08k6sca">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=taking_full_control</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:intermediateThrowEvent id="Event_08k6sca" name="Human control required">
        <bpmn:incoming>Flow_0d8294a</bpmn:incoming>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_0yw2iu1" escalationRef="Escalation_2jvfsk2" />
      </bpmn:intermediateThrowEvent>
      <bpmn:scriptTask id="Task_CalculateLoanRepaymentsAndAssessAffordability" name="Calculate loan repayments and assess affordability">
        <bpmn:documentation>Call this to calculate loan repayment amount</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;  &#34;monthlyInterestRate&#34;: interestRate / 12 / 100,&#10;  &#34;monthlyPayment&#34;: (loanAmount * monthlyInterestRate) / (1 - (1 + monthlyInterestRate)**-loanTermInMonths),&#10;  &#34;annualPayment&#34;: monthlyPayment * 12,&#10;  &#34;affordable&#34;: yearlySalary * 0.33 &#62; annualPayment&#10;}" resultVariable="toolCallResult" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.interestRate, &#34;The interest rate for the loan.&#34;, &#34;number&#34;)" target="interestRate" />
            <zeebe:input source="=fromAi(toolCall.yearlyIncome, &#34;The yearly income of the household.&#34;, &#34;number&#34;)" target="yearlySalary" />
            <zeebe:input source="=fromAi(toolCall.loanTermInYear, &#34;The loan term in years.&#34;, &#34;number&#34;) * 12" target="loanTermInMonths" />
            <zeebe:input source="=fromAi(toolCall.loanAmount, &#34;The loan amount for this project.&#34;, &#34;number&#34;)" target="loanAmount" />
            <zeebe:input source="=&#34;Calculating loan repayments&#34;" target="botThinking" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:manualTask id="Task_AdjustLoanScheduleInSAP" name="Adjust loan schedule in SAP CML" zeebe:modelerTemplate="0f11c756-78d1-4964-b9b6-f2dd7c9c47ea" zeebe:modelerTemplateVersion="1751635692917" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>This activity can adjust the loan payments for one loan identitfied by the variable loanId</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:sap-odata:2" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=&#34;Adjusting loan schedule in SAP&#34;" target="botThinking" />
            <zeebe:input source="a4h" target="destination" />
            <zeebe:input source="/sap/opu/odata/dmo/case" target="oDataService" />
            <zeebe:input source="simpleReq" target="requestDetails.requestType" />
            <zeebe:input source="=loan( loanId )" target="requestDetails.entityOrEntitySet" />
            <zeebe:input source="get" target="requestDetails.httpMethod.httpMethod" />
            <zeebe:input source="V2" target="requestDetails.httpMethod.oDataVersionGet.oDataVersionGet" />
            <zeebe:input source="=false" target="requestDetails.httpMethod.oDataVersionGet.inlinecount" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:manualTask>
      <bpmn:serviceTask id="Task_SaveInKnowledgeBase" name="Save answer in knowledge base" zeebe:modelerTemplate="io.camunda.connectors.EmbeddingsVectorDB.v1" zeebe:modelerTemplateVersion="2" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:embeddings-vector-database:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="embedDocumentOperation" target="vectorDatabaseConnectorOperation.operationType" />
            <zeebe:input source="bedrockModelProvider" target="embeddingModelProvider.modelProvider" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="embeddingModelProvider.bedrock.accessKey" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="embeddingModelProvider.bedrock.secretKey" />
            <zeebe:input source="us-east-1" target="embeddingModelProvider.bedrock.region" />
            <zeebe:input source="TitanEmbedTextV2" target="embeddingModelProvider.bedrock.modelName" />
            <zeebe:input source="D1024" target="embeddingModelProvider.bedrock.dimensions" />
            <zeebe:input source="=false" target="embeddingModelProvider.bedrock.normalize" />
            <zeebe:input source="=3" target="embeddingModelProvider.bedrock.maxRetries" />
            <zeebe:input source="amazonManagedOpenSearchStore" target="vectorStore.storeType" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="vectorStore.amazonManagedOpensearch.accessKey" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="vectorStore.amazonManagedOpensearch.secretKey" />
            <zeebe:input source="{{secrets.OPENSEARCH_ENDPOINT}}" target="vectorStore.amazonManagedOpensearch.serverUrl" />
            <zeebe:input source="us-east-1" target="vectorStore.amazonManagedOpensearch.region" />
            <zeebe:input source="specialist-knowledge-base-keynote" target="vectorStore.amazonManagedOpensearch.indexName" />
            <zeebe:input source="PlainText" target="vectorDatabaseConnectorOperation.documentSource" />
            <zeebe:input source="=toolResult" target="vectorDatabaseConnectorOperation.documentSourceFromProcessVariable" />
            <zeebe:input source="recursiveDocumentSplitter" target="vectorDatabaseConnectorOperation.documentSplitter.splitterType" />
            <zeebe:input source="=500" target="vectorDatabaseConnectorOperation.documentSplitter.maxSegmentSizeInChars" />
            <zeebe:input source="=80" target="vectorDatabaseConnectorOperation.documentSplitter.maxOverlapSizeInChars" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="2" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.EmbeddingsVectorDB.v1" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_01md30m</bpmn:incoming>
        <bpmn:outgoing>Flow_1ch34l1</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_query_knowledge_base" name="Query knowledge base" zeebe:modelerTemplate="io.camunda.connectors.EmbeddingsVectorDB.v1" zeebe:modelerTemplateVersion="2" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this activity to search company knowledge base for general answers</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:embeddings-vector-database:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="retrieveDocumentOperation" target="vectorDatabaseConnectorOperation.operationType" />
            <zeebe:input source="=fromAi(toolCall.query, &#34;The knowledge base query you want to perform&#34;)" target="vectorDatabaseConnectorOperation.query" />
            <zeebe:input source="=5" target="vectorDatabaseConnectorOperation.documentLimit" />
            <zeebe:input source="bedrockModelProvider" target="embeddingModelProvider.modelProvider" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="embeddingModelProvider.bedrock.accessKey" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="embeddingModelProvider.bedrock.secretKey" />
            <zeebe:input source="us-east-1" target="embeddingModelProvider.bedrock.region" />
            <zeebe:input source="TitanEmbedTextV2" target="embeddingModelProvider.bedrock.modelName" />
            <zeebe:input source="D1024" target="embeddingModelProvider.bedrock.dimensions" />
            <zeebe:input source="=false" target="embeddingModelProvider.bedrock.normalize" />
            <zeebe:input source="=3" target="embeddingModelProvider.bedrock.maxRetries" />
            <zeebe:input source="amazonManagedOpenSearchStore" target="vectorStore.storeType" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="vectorStore.amazonManagedOpensearch.accessKey" />
            <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="vectorStore.amazonManagedOpensearch.secretKey" />
            <zeebe:input source="{{secrets.OPENSEARCH_ENDPOINT}}" target="vectorStore.amazonManagedOpensearch.serverUrl" />
            <zeebe:input source="us-east-1" target="vectorStore.amazonManagedOpensearch.region" />
            <zeebe:input source="specialist-knowledge-base-keynote" target="vectorStore.amazonManagedOpensearch.indexName" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="2" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.EmbeddingsVectorDB.v1" />
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="errorExpression" value="=if contains(error.message, &#34;index_not_found&#34;) then bpmnError(&#34;index_not_found&#34;, &#34;The index does not exist&#34;) else null" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:callActivity id="CallActivity_LoanApplication" name="Consumer Loan Application">
        <bpmn:documentation>Whenever a concrete loan is requested by the customer use this tool to go through a proper loan application process</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledElement processId="loan-application" propagateAllChildVariables="false" propagateAllParentVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=supportCase.communicationContext" target="communicationContext" />
            <zeebe:input source="={&#10;  customerId: supportCase.customer.id,&#10;  lastName:  supportCase.customer.name,&#10;  firstName: supportCase.customer.firstname,&#10;  newCustomer: false,&#10;  emailAddress:  supportCase.customer.email,&#10;  requestedTerm: fromAi(toolCall.requestedTerm, &#34;The loan repayment months&#34;),&#10;  amountRequested: fromAi(toolCall.amountRequested, &#34;The amount of the loan&#34;),&#10;  moreData: &#34;...&#34;&#10;}" target="loanApplication" />
            <zeebe:input source="=chatUniqueId" target="chatUniqueId" />
            <zeebe:input source="=&#34;Handling loan application&#34;" target="botThinking" />
            <zeebe:output source="=communicationResult" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:callActivity>
      <bpmn:serviceTask id="Task_LoadAvailableHomeLoanProducts" name="Load available home loan products" zeebe:modelerTemplate="e529d927-3534-413f-ab72-430d56a69052" zeebe:modelerTemplateVersion="1751701487875" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this activity to load home loan products</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=&#34;Retrieving loan options&#34;" target="botThinking" />
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="LoanOffer" target="entity" />
            <zeebe:input source="search" target="action" />
            <zeebe:input source="=if (action=&#34;update&#34;) then &#34;PUT&#34; else if (action=&#34;patch&#34;) then &#34;PATCH&#34; else if (action=&#34;delete&#34;) then &#34;DELETE&#34; else &#34;POST&#34;" target="method" />
            <zeebe:input source="=if (action=&#34;update&#34; or action=&#34;delete&#34; or action=&#34;patch&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/&#34;+entityKey else if (action=&#34;search&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/search&#34; else &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="type:Home" target="luceneQuery" />
            <zeebe:input source="=10" target="pageSize" />
            <zeebe:input source="=if (action=&#34;search&#34;) then {&#10;  &#34;luceneQuery&#34;: luceneQuery,&#10;  &#34;page&#34;: 1,&#10;  &#34;pageSize&#34;: pageSize&#10;} else payload" target="body" />
            <zeebe:input source="=false" target="ignoreNullValues" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_LoadAvailableConsumerLoanProducts" name="Load available consumer loan products" zeebe:modelerTemplate="e529d927-3534-413f-ab72-430d56a69052" zeebe:modelerTemplateVersion="1751701487875" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this activity to load consumer loan products</bpmn:documentation>

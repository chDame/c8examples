<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_04o12p6" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="72f97ba" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="banking-support-agent" isExecutable="true">
    <bpmn:adHocSubProcess id="AI_CustomerSupportAgent" name="Customer Support Agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Finding best approach&#34;" target="chatbotThinking" />
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="us-east-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_ID}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY_SECRET}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-20250514-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=5000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=0.2" target="provider.bedrock.model.parameters.temperature" />
          <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.topP" />
          <zeebe:input source="=&#34;&#10;You are the routing agent for Camunda Bank’s shared inbox.&#10;Decide which tool to call for each customer message.&#10;If the message is ambiguous, small talk, or lacks a clear banking intent, FIRST call Tool_AskCustomer to politely clarify their need. Only call Tool_InformCustomer to deliver information that does not ask a question and typically ends the case.&#10;&#10;CRITICAL OUTPUT RULES&#10;- Always invoke tools via function/tool-calling. Do NOT print tool JSON in content.&#10;- Prefer calling tools over free text. Only write content through the communication tools.&#10;- Customer communication rule:&#10;  * If your reply contains a QUESTION (even a short one), you MUST use Tool_AskCustomer—not Tool_InformCustomer.&#10;  * Use Tool_InformCustomer only for final, non-question statements that dont expect a reply.&#10;  * IMPORTANT: If you called a specialized sub-agent (Account Support Agent, Loan Support Agent) that handles its own customer communication, DO NOT call Tool_AskCustomer or Tool_InformCustomer afterward. The sub-agent has already handled all customer communication.&#10;  * If no sub-agent ran and you plan to close the task, ensure the customer received a summary via Tool_InformCustomer.&#10;&#10;TOOL SELECTION &#38; ORDERING&#10;- Inspect the available tools and choose the best tool; call multiple tools if needed.&#10;- If intent is unclear → Tool_AskCustomer until it is clarified.&#10;- If the request is out of scope (e.g., weather, sports, traffic, general info) → inform the customer and politely explain scope and offer banking help. Then close.&#10;&#10;PRIVACY&#10;- Treat the sender as a customer. Never invent PII.&#10;- Treat the customer as authenticated.&#10;&#10;SELF-CHECK BEFORE RESPONDING&#10;- Did I call a specialized sub-agent (CallActivity_AccountSupportAgent, CallActivity_LoanSupportAgent) that handles its own customer communication? If yes → DO NOT call Tool_AskCustomer or Tool_InformCustomer afterward. End the task cleanly.&#10;- Does my message include a question AND no sub-agent with communication was called? If yes → Tool_AskCustomer.&#10;- Did only tools without customer communication run, and am I about to close? If yes → ensure I called Tool_InformCustomer in this run first.&#10;- Is it bank-related but no specialized tool handles it? If yes → Tool_OtherInquiry.&#10;&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=supportCase.request" target="data.userPrompt.prompt" />
          <zeebe:input source="=agent.context" target="agentContext" />
          <zeebe:input source="camunda-document" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agentResult" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0fv4284</bpmn:incoming>
      <bpmn:outgoing>Flow_1nojswc</bpmn:outgoing>
      <bpmn:callActivity id="CallActivity_AccountSupportAgent" name="Account Support Agent">
        <bpmn:documentation>Sub agent to handle any account related requests. The agent will handle the request in full, including any customer communication. So when it ends you don't need to communicate with the customer any more but can end the task.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledElement processId="account-support-agent" propagateAllChildVariables="false" propagateAllParentVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=put(supportCase, &#34;request&#34;, fromAi(toolCall.userInquiry, &#34;The relevant user request as extracted from the email for this agent using the original customer wording&#34;))" target="supportCase" />
            <zeebe:input source="=if chatUniqueId!=null then chatUniqueId else &#34;&#34;" target="chatUniqueId" />
            <zeebe:input source="=&#34;Addressing Account request&#34;" target="chatbotThinking" />
            <zeebe:output source="=response" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:callActivity>
      <bpmn:callActivity id="CallActivity_LoanSupportAgent" name="Loan Support Agent">
        <bpmn:documentation>Sub agent to handle any loan related requests. The agent will handle the request in full, including any customer communication. So when it ends you don't need to communicate with the customer any more but can end the task.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledElement processId="loan-support-agent" propagateAllChildVariables="false" propagateAllParentVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=put(supportCase, &#34;request&#34;, fromAi(toolCall.userInquiry, &#34;The relevant user request as extracted from the email for this agent using the original customer wording&#34;))" target="supportCase" />
            <zeebe:input source="=if chatUniqueId!=null then chatUniqueId else &#34;&#34;" target="chatUniqueId" />
            <zeebe:input source="=&#34;Addressing Loan request&#34;" target="chatbotThinking" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:callActivity>
      <bpmn:serviceTask id="Tool_A2A_CreditCardAgent" name="Card Support Agent&#10;(A2A Client)" zeebe:modelerTemplate="dev.example.a2a.connector.outbound" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Handle card related inquiries (e.g. to report a stolen card or to freeze a card). This agent doesn't include communication with the customer, so always communicate its result to the customer.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="dev.example:a2a:1" />
          <zeebe:ioMapping>
            <zeebe:input source="=&#34;Addressing card support request&#34;" target="chatbotThinking" />
            <zeebe:input source="=&#34;http://localhost:8000/a2a/&#34;" target="baseUrl" />
            <zeebe:input source="=&#34;A2A&#34;" target="mode" />
            <zeebe:input target="inputText" />
            <zeebe:input target="intent" />
            <zeebe:input target="parameters" />
            <zeebe:input target="headers" />
            <zeebe:input source="= {&#10;  &#34;jsonrpc&#34;: &#34;2.0&#34;,&#10;  &#34;id&#34;: &#34;475478&#34;,&#10;  &#34;method&#34;: &#34;message/send&#34;,&#10;  &#34;params&#34;: {&#10;    &#34;message&#34;: {&#10;      &#34;messageId&#34;: &#34;m-123&#34;,&#10;      &#34;role&#34;: &#34;user&#34;,&#10;      &#34;parts&#34;: [&#10;        { &#34;text&#34;: fromAi(toolCall.creditCardAgentIstructions, &#34;The instructions/prompt for the card agent&#34;) }&#10;      ]&#10;    }&#10;  }&#10;}" target="a2aPayload" />
            <zeebe:output source="={&#34;body&#34;: body, &#34;statusCode&#34;: statusCode}" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:callActivity id="Tool_AskCustomer" name="Ask customer">
        <bpmn:documentation>Use for ANY message that includes a question or clarification. If you’re asking the customer anything, you MUST use this tool.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledElement processId="customer-communication-question" propagateAllChildVariables="false" propagateAllParentVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=supportCase.communicationContext" target="communicationContext" />
            <zeebe:input source="={&#10;  &#34;subject&#34;: &#34;RE: &#34; + supportCase.subject,&#10;  &#34;text&#34;: fromAi(toolCall.response, &#34;The text response to reply to the customer&#34;)&#10;}" target="communicationContent" />
            <zeebe:input source="=if chatUniqueId!=null then chatUniqueId else &#34;&#34;" target="chatUniqueId" />
            <zeebe:input source="=&#34;Need more informations&#34;" target="chatbotThinking" />
            <zeebe:output source="=communicationResult" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:callActivity>
      <bpmn:callActivity id="Tool_InformCustomer" name="Inform&#10;customer">
        <bpmn:documentation>Use only to deliver final information/statement; NEVER include a question.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledElement processId="customer-communication-information" propagateAllChildVariables="false" propagateAllParentVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=supportCase.communicationContext" target="communicationContext" />
            <zeebe:input source="={&#10;  &#34;subject&#34;: &#34;RE: &#34; + supportCase.subject,&#10;  &#34;text&#34;: fromAi(toolCall.response, &#34;The text information for the customer, probably the case resolution&#34;)&#10;}" target="communicationContent" />
            <zeebe:input source="=if chatUniqueId!=null then chatUniqueId else &#34;&#34;" target="chatUniqueId" />
            <zeebe:input source="=&#34;Informing customer&#34;" target="chatbotThinking" />
            <zeebe:output source="=communicationResult" target="toolCallResult" />
          </zeebe:ioMapping>
          <zeebe:executionListeners>
            <zeebe:executionListener eventType="start" type="chatbotThinking" />
          </zeebe:executionListeners>
        </bpmn:extensionElements>
      </bpmn:callActivity>
      <bpmn:subProcess id="Tool_LegalInquiry" name="Legal questions">
        <bpmn:documentation>Use this tool to handle all inquiries related to legal matters. It will be handled by a human. The subflow owns customer communication. So when it ends do NOT communicate with the customer any more but end the task.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.customerNotification, &#34;A text information for the customer that his inquiry gets routed to a human to resolve&#34;)" target="customerNote" />
            <zeebe:input source="=fromAi(toolCall.requestToHuman, &#34;Describe what the specialist needs to do for the customer. Summarize in your own words - ideally easy to get bullet points, but attach the original customer request below for reference&#34;, &#34;string&#34;)" target="requestDetails" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:startEvent id="Event_16i94kb">
          <bpmn:outgoing>Flow_0ipl283</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:callActivity id="Activity_0iojs56" name="Inform&#10;customer">
          <bpmn:extensionElements>
            <zeebe:calledElement processId="customer-communication-information" propagateAllChildVariables="false" propagateAllParentVariables="false" />
            <zeebe:ioMapping>
              <zeebe:input source="=supportCase.communicationContext" target="communicationContext" />
              <zeebe:input source="={&#10;  &#34;subject&#34;: &#34;RE: &#34; + supportCase.subject,&#10;  &#34;text&#34;: customerNote&#10;}" target="communicationContent" />
              <zeebe:input source="=if chatUniqueId!=null then chatUniqueId else &#34;&#34;" target="chatUniqueId" />
              <zeebe:input source="=&#34;Informing customer&#34;" target="chatbotThinking" />
              <zeebe:output source="=communicationResult" target="toolCallResult" />
            </zeebe:ioMapping>
            <zeebe:executionListeners>
              <zeebe:executionListener eventType="start" type="chatbotThinking" />
            </zeebe:executionListeners>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_0ipl283</bpmn:incoming>
          <bpmn:outgoing>Flow_1gebtgn</bpmn:outgoing>
        </bpmn:callActivity>
        <bpmn:endEvent id="Event_15byyie">
          <bpmn:incoming>Flow_0jt410e</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_0ipl283" sourceRef="Event_16i94kb" targetRef="Activity_0iojs56" />
        <bpmn:userTask id="UserTask_HandleLegalQuestions" name="Handle legal questions">
          <bpmn:extensionElements>
            <zeebe:userTask />
            <zeebe:formDefinition formId="Form_HumanHandling" />
            <zeebe:ioMapping>
              <zeebe:input source="=fromAi(toolCall.requestToHuman, &#34;Describe what the specialist needs to do for the customer. Summarize in your own words - ideally easy to get bullet points, but attach the original customer request below for reference&#34;, &#34;string&#34;)" target="requestDetails" />
            </zeebe:ioMapping>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_1gebtgn</bpmn:incoming>
          <bpmn:outgoing>Flow_0jt410e</bpmn:outgoing>
        </bpmn:userTask>
        <bpmn:sequenceFlow id="Flow_1gebtgn" sourceRef="Activity_0iojs56" targetRef="UserTask_HandleLegalQuestions" />
        <bpmn:sequenceFlow id="Flow_0jt410e" sourceRef="UserTask_HandleLegalQuestions" targetRef="Event_15byyie" />
      </bpmn:subProcess>
      <bpmn:subProcess id="Tool_OtherInquiry" name="Other inquiries">
        <bpmn:documentation>Use this tool to handle banking related inquiries that are not handled by a more specialized tool. 
The subflow owns customer communication. So when it ends do NOT communicate with the customer any more but end the task.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.customerNotification, &#34;A text information for the customer that his inquiry gets routed to a human to resolve&#34;)" target="customerNote" />
            <zeebe:input source="=fromAi(toolCall.requestToHuman, &#34;Describe what the specialist needs to do for the customer. Summarize in your own words - ideally easy to get bullet points, but attach the original customer request below for reference&#34;, &#34;string&#34;)" target="requestDetails" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:callActivity id="Activity_0brf0nb" name="Inform&#10;customer">
          <bpmn:extensionElements>
            <zeebe:calledElement processId="customer-communication-information" propagateAllChildVariables="false" propagateAllParentVariables="false" />
            <zeebe:ioMapping>
              <zeebe:input source="=supportCase.communicationContext" target="communicationContext" />
              <zeebe:input source="={&#10;  &#34;subject&#34;: &#34;RE: &#34; + supportCase.subject,&#10;  &#34;text&#34;: customerNote&#10;}" target="communicationContent" />
              <zeebe:input source="=if chatUniqueId!=null then chatUniqueId else &#34;&#34;" target="chatUniqueId" />
              <zeebe:input source="=&#34;Informing customer&#34;" target="chatbotThinking" />
              <zeebe:output source="=communicationResult" target="toolCallResult" />
            </zeebe:ioMapping>
            <zeebe:executionListeners>
              <zeebe:executionListener eventType="start" type="chatbotThinking" />
            </zeebe:executionListeners>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_00kl5bg</bpmn:incoming>
          <bpmn:outgoing>Flow_00r5pe0</bpmn:outgoing>
        </bpmn:callActivity>
        <bpmn:startEvent id="Event_1v6eq54">
          <bpmn:outgoing>Flow_00kl5bg</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:endEvent id="Event_0touz25">
          <bpmn:incoming>Flow_1ar2l39</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_00kl5bg" sourceRef="Event_1v6eq54" targetRef="Activity_0brf0nb" />
        <bpmn:sequenceFlow id="Flow_00r5pe0" sourceRef="Activity_0brf0nb" targetRef="UserTask_HandleOtherInquiries" />
        <bpmn:userTask id="UserTask_HandleOtherInquiries" name="Handle other inquiries">
          <bpmn:extensionElements>
            <zeebe:userTask />
            <zeebe:formDefinition formId="Form_HumanHandling" />
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_00r5pe0</bpmn:incoming>
          <bpmn:outgoing>Flow_1ar2l39</bpmn:outgoing>
        </bpmn:userTask>
        <bpmn:sequenceFlow id="Flow_1ar2l39" sourceRef="UserTask_HandleOtherInquiries" targetRef="Event_0touz25" />
      </bpmn:subProcess>
    </bpmn:adHocSubProcess>
    <bpmn:exclusiveGateway id="Gateway_1sbtuh2" name="Review (exemplary samples)?">
      <bpmn:incoming>Flow_0xnx5gq</bpmn:incoming>
      <bpmn:outgoing>Flow_0g2kbqn</bpmn:outgoing>
      <bpmn:outgoing>Flow_19tm0v8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0g2kbqn" name="yes (1%)" sourceRef="Gateway_1sbtuh2" targetRef="Activity_04lvuy1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_13awtny">
      <bpmn:incoming>Flow_19tm0v8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_19tm0v8" name="no (99%)" sourceRef="Gateway_1sbtuh2" targetRef="Event_13awtny">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_1sx7tol">
      <bpmn:incoming>Flow_1w8zj7s</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1w8zj7s" sourceRef="Activity_04lvuy1" targetRef="Event_1sx7tol" />
    <bpmn:userTask id="Activity_04lvuy1" name="Review support resolution">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0g2kbqn</bpmn:incoming>
      <bpmn:outgoing>Flow_1w8zj7s</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_Email" name="Customer email received" zeebe:modelerTemplate="io.camunda.connectors.inbound.EmailMessageStart.v1" zeebe:modelerTemplateVersion="2" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="inbound.type" value="io.camunda:connector-email-inbound:1" />
          <zeebe:property name="authentication.type" value="simple" />
          <zeebe:property name="authentication.username" value="{{secrets.INBOUND_MAIL_USER}}" />
          <zeebe:property name="authentication.password" value="{{secrets.INBOUND_MAIL_PASSWORD}}" />
          <zeebe:property name="data.imapConfig.imapHost" value="{{secrets.INBOUND_MAIL_SERVER}}" />
          <zeebe:property name="data.imapConfig.imapPort" value="{{secrets.INBOUND_MAIL_IMAP_PORT}}" />
          <zeebe:property name="data.imapConfig.imapCryptographicProtocol" value="TLS" />
          <zeebe:property name="data.folderToListen" value="{{secrets.INBOUND_MAIL_FOLDER}}" />
          <zeebe:property name="data.pollingWaitTime" value="PT10S" />
          <zeebe:property name="data.pollingConfigDiscriminator" value="unseenPollingConfig" />
          <zeebe:property name="data.pollingConfig.handlingStrategy" value="READ" />
          <zeebe:property name="activationCondition" value="=is empty(headers[key = &#34;In-Reply-To&#34;])" />
          <zeebe:property name="consumeUnmatchedEvents" value="false" />
          <zeebe:property name="correlationRequired" value="notRequired" />
          <zeebe:property name="deduplicationModeManualFlag" value="false" />
          <zeebe:property name="deduplicationMode" value="AUTO" />
          <zeebe:property name="resultVariable" value="currentEmail" />
          <zeebe:property name="resultExpression" value="={&#10;  customerRequest: plainTextBody,&#10;  communicationChannel: &#34;email&#34;,&#10;  supportCase: {&#10;    subject: subject,&#10;    request: plainTextBody,&#10;    communicationContext: {&#10;        channel: &#34;email&#34;,&#10;        emailAddress: fromAddress,&#10;        conversationId: messageId&#10;    }&#10;  }&#10;}" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_17hp3tr</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1ygmb0p" messageRef="Message_16m9y1n" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_17hp3tr" sourceRef="StartEvent_Email" targetRef="Gateway_0b8kgrt" />
    <bpmn:startEvent id="StartEvent_Blank" name="Customer support request received (other channels)">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=context merge([supportCase,  {&#34;communicationContext&#34;: {&#10;        &#34;channel&#34; : &#34;email&#34;,&#10;        &#34;channelId&#34;: null,&#10;        &#34;emailAddress&#34;: email,&#10;        &#34;conversationId&#34;: null&#10;    }}])" target="supportCase" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_04dj9kf</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_04dj9kf" sourceRef="StartEvent_Blank" targetRef="Gateway_0b8kgrt" />
    <bpmn:sequenceFlow id="Flow_1i0kcwv" sourceRef="StartEvent_Chat" targetRef="Activity_1l7avgo" />
    <bpmn:startEvent id="Event_0nn09te" name="Customer phoned in">
      <bpmn:extensionElements>
        <zeebe:ioMapping>

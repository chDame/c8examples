      <bpmn:documentation>Always query customer data</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="Customer" target="entity" />
          <zeebe:input source="search" target="action" />
          <zeebe:input source="=if (action=&#34;update&#34;) then &#34;PUT&#34; else if (action=&#34;patch&#34;) then &#34;PATCH&#34; else if (action=&#34;delete&#34;) then &#34;DELETE&#34; else &#34;POST&#34;" target="method" />
          <zeebe:input source="=if (action=&#34;update&#34; or action=&#34;delete&#34; or action=&#34;patch&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/&#34;+entityKey else if (action=&#34;search&#34;) then &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity+&#34;/search&#34; else &#34;{{secrets.RSP_URL}}/api/data/&#34;+entity" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=&#34;email:\&#34;&#34;+email+&#34;\&#34;&#34;" target="luceneQuery" />
          <zeebe:input source="=10" target="pageSize" />
          <zeebe:input source="=if (action=&#34;search&#34;) then {&#10;  &#34;luceneQuery&#34;: luceneQuery,&#10;  &#34;page&#34;: 1,&#10;  &#34;pageSize&#34;: pageSize&#10;} else payload" target="body" />
          <zeebe:input source="=false" target="ignoreNullValues" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="response" />
          <zeebe:header key="resultExpression" value="={&#10;  customerData: response.body.items[1]&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1mprn5y</bpmn:incoming>

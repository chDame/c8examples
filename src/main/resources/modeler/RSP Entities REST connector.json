{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "RSP entity Connector",
  "id": "e529d927-3534-413f-ab72-430d56a69052",
  "version": 1751701487875,
  "description": "Invoke RSP entity REST API",
  "metadata": {
    "keywords": []
  },
  "documentationRef": "https://docs.camunda.io/docs/components/connectors/protocol/rest/",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "authentication",
      "label": "Authentication"
    },
    {
      "id": "endpoint",
      "label": "HTTP endpoint"
    },
    {
      "id": "output",
      "label": "Output mapping"
    },
    {
      "id": "timeout",
      "label": "Connection timeout"
    },
    {
      "id": "payload",
      "label": "Payload"
    },
    {
      "id": "error",
      "label": "Error handling"
    },
    {
      "id": "retries",
      "label": "Retries"
    }
  ],
  "properties": [
    {
      "value": "io.camunda:http-json:1",
      "binding": {
        "property": "type",
        "type": "zeebe:taskDefinition"
      },
      "type": "Hidden"
    },
    {
      "id": "authentication.type",
      "label": "Type",
      "description": "Choose the authentication type. Select 'None' if no authentication is necessary",
      "value": "noAuth",
      "group": "authentication",
      "binding": {
        "name": "authentication.type",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "entity",
      "label": "Entity",
      "optional": false,
      "value": "LoanOffer",
      "constraints": {
        "notEmpty": true
      },
      "group": "endpoint",
      "binding": {
        "name": "entity",
        "type": "zeebe:input"
      },
      "type": "Dropdown",
      "choices": [
        {
          "name": "LoanOffer",
          "value": "LoanOffer"
        },
        {
          "name": "Loan",
          "value": "Loan"
        },
        {
          "name": "Customer",
          "value": "Customer"
        }
      ]
    },
    {
      "id": "action",
      "label": "Action",
      "optional": false,
      "value": "search",
      "constraints": {
        "notEmpty": true
      },
      "group": "endpoint",
      "binding": {
        "name": "action",
        "type": "zeebe:input"
      },
      "type": "Dropdown",
      "choices": [
        {
          "name": "Search",
          "value": "search"
        },
        {
          "name": "Create",
          "value": "create"
        },
        {
          "name": "Update",
          "value": "update"
        },
        {
          "name": "Patch",
          "value": "patch"
        },
        {
          "name": "Delete",
          "value": "delete"
        }
      ]
    },
    {
      "id": "entityKey",
      "label": "Entity Key",
      "optional": false,
      "feel": "optional",
      "group": "endpoint",
      "binding": {
        "name": "entityKey",
        "type": "zeebe:input"
      },
      "type": "String",
      "value": "",
      "condition": {
        "property": "action",
        "oneOf": [
          "delete",
          "update"
        ],
        "type": "simple"
      }
    },
    {
      "id": "method",
      "label": "Method",
      "optional": false,
      "value": "=if (action=\"update\") then \"PUT\" else if (action=\"patch\") then \"PATCH\" else if (action=\"delete\") then \"DELETE\" else \"POST\"",
      "constraints": {
        "notEmpty": true
      },
      "group": "endpoint",
      "binding": {
        "name": "method",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "url",
      "label": "URL",
      "optional": false,
      "group": "endpoint",
      "binding": {
        "name": "url",
        "type": "zeebe:input"
      },
      "type": "Hidden",
      "value": "=if (action=\"update\" or action=\"delete\" or action=\"patch\") then \"{{secrets.RSP_URL}}/api/data/\"+entity+\"/\"+entityKey else if (action=\"search\") then \"{{secrets.RSP_URL}}/api/data/\"+entity+\"/search\" else \"{{secrets.RSP_URL}}/api/data/\"+entity"
    },
    {
      "id": "headers",
      "label": "Headers",
      "description": "Map of HTTP headers to add to the request",
      "optional": true,
      "group": "endpoint",
      "binding": {
        "name": "headers",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "queryParameters",
      "label": "Query parameters",
      "description": "Map of query parameters to add to the request URL",
      "optional": true,
      "group": "endpoint",
      "binding": {
        "name": "queryParameters",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "storeResponse",
      "label": "Store response",
      "description": "Store the response as a document in the document store",
      "optional": false,
      "value": "=false",
      "group": "endpoint",
      "binding": {
        "name": "storeResponse",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "skipEncoding",
      "label": "Skip URL encoding",
      "description": "Skip the default URL decoding and encoding behavior",
      "optional": true,
      "group": "endpoint",
      "binding": {
        "name": "skipEncoding",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "payload",
      "label": "Object payload",
      "description": "the object payload to create or update",
      "optional": false,
      "feel": "optional",
      "group": "endpoint",
      "binding": {
        "name": "payload",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "action",
        "oneOf": [
          "create",
          "update"
        ],
        "type": "simple"
      },
      "type": "Text",
      "value": ""
    },
    {
      "id": "luceneQuery",
      "label": "Lucene query",
      "description": "Lucene query",
      "optional": false,
      "feel": "optional",
      "group": "endpoint",
      "binding": {
        "name": "luceneQuery",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "action",
        "oneOf": [
          "search"
        ],
        "type": "simple"
      },
      "type": "Text",
      "value": ""
    },
    {
      "id": "pageSize",
      "label": "Number of results",
      "description": "Number of results to fetch",
      "optional": false,
      "value": "=10",
      "constraints": {
        "notEmpty": true,
        "pattern": {
          "value": "^\\d+$",
          "message": "Must be a number"
        }
      },
      "condition": {
        "property": "action",
        "oneOf": [
          "search"
        ],
        "type": "simple"
      },
      "feel": "optional",
      "group": "endpoint",
      "binding": {
        "name": "pageSize",
        "type": "zeebe:input"
      },
      "type": "Number"
    },
    {
      "id": "body",
      "label": "Request body",
      "description": "Payload to send with the request",
      "optional": true,
      "group": "payload",
      "binding": {
        "name": "body",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "action",
        "oneOf": [
          "create",
          "update",
          "search"
        ],
        "type": "simple"
      },
      "type": "Hidden",
      "value": "=if (action=\"search\") then {\n  \"luceneQuery\": luceneQuery,\n  \"page\": 1,\n  \"pageSize\": pageSize\n} else payload"
    },
    {
      "id": "ignoreNullValues",
      "label": "Ignore null values",
      "optional": false,
      "value": "=false",
      "group": "payload",
      "binding": {
        "name": "ignoreNullValues",
        "type": "zeebe:input"
      },
      "tooltip": "Null values will not be sent",
      "type": "Hidden"
    },
    {
      "id": "resultVariable",
      "label": "Result variable",
      "description": "Name of variable to store the response in",
      "group": "output",
      "binding": {
        "key": "resultVariable",
        "type": "zeebe:taskHeader"
      },
      "type": "String",
      "value": "response"
    },
    {
      "id": "resultExpression",
      "label": "Result expression",
      "description": "Expression to map the response into process variables",
      "feel": "required",
      "group": "output",
      "binding": {
        "key": "resultExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "errorExpression",
      "label": "Error expression",
      "description": "Expression to handle errors. Details in the <a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/\" target=\"_blank\">documentation</a>.",
      "feel": "required",
      "group": "error",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "description": "Number of retries",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "connectionTimeoutInSeconds",
      "label": "Connection timeout in seconds",
      "description": "Defines the connection timeout in seconds, or 0 for an infinite timeout",
      "optional": false,
      "value": "=20",
      "constraints": {
        "notEmpty": true,
        "pattern": {
          "value": "^\\d+$",
          "message": "Must be a number"
        }
      },
      "feel": "static",
      "group": "timeout",
      "binding": {
        "name": "connectionTimeoutInSeconds",
        "type": "zeebe:input"
      },
      "type": "Number"
    },
    {
      "id": "readTimeoutInSeconds",
      "label": "Read timeout in seconds",
      "description": "Timeout in seconds to read data from an established connection or 0 for an infinite timeout",
      "optional": false,
      "value": "=20",
      "constraints": {
        "notEmpty": true,
        "pattern": {
          "value": "^\\d+$",
          "message": "Must be a number"
        }
      },
      "feel": "static",
      "group": "timeout",
      "binding": {
        "name": "readTimeoutInSeconds",
        "type": "zeebe:input"
      },
      "type": "Number"
    },
    {
      "id": "retryBackoff",
      "label": "Retry backoff",
      "description": "ISO-8601 duration to wait between retries",
      "value": "PT0S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}
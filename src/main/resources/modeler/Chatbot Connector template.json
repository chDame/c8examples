{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Chatbot • Reply",
  "id": "chatbotReply",
  "version": 3,
  "description": "Sends a reply message to a conversation in the chat.",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "behaviour",
      "label": "Behaviour"
    }
  ],
  "properties": [
    {
      "type": "Hidden",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "type"
      },
      "value": "chatbotReply"
    },
    {
      "type": "Hidden",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "retries"
      },
      "value": "3"
    },
    {
      "type": "Boolean",
      "binding": {
        "type": "zeebe:input",
        "name": "waitResponse"
      },
      "value": true,
      "label": "Wait for a response",
      "group": "behaviour"
    },
    {
      "type": "String",
      "binding": {
        "type": "zeebe:input",
        "name": "chatbotMessage"
      },
      "value": "=fromAi(toolCall.response, \"The text response to reply to the customer\")",
      "label": "Chatbot message",
      "group": "behaviour"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}